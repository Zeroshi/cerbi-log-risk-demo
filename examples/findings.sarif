                  "startColumn": 5
                }
              }
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Replace \u0027{{ rawBody }}\u0027 with individually named safe fields. If body inspection is required for debugging, apply a content-filtering or redaction pipeline before logging."
              }
            }
          ]
        },
        {
          "ruleId": "CERBI003",
